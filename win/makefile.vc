!if "$(STAGINGDIR)" == ""
STAGINGDIR = ..\staging
!endif
TCLSH_NATIVE=..\staging\bin\tclsh91s.exe
PROJECT=sfe
DOTVERSION=9.1
NEED_TK=1

!include $(TCLDIR)\win\rules-ext.vc

!if exists($(STAGINGDIR)\tclsfe_nmake.inc)
!include $(STAGINGDIR)\tclsfe_nmake.inc
!endif

PRJ_OBJS = $(TMP_DIR)\tclSfeMainHook.obj
PRJ_LIBS = $(TCLSFE_LIBS) netapi32.lib gdi32.lib user32.lib userenv.lib \
        winspool.lib shell32.lib ole32.lib uuid.lib oleacc.lib usp10.lib \
        dwmapi.lib

PRJ_DEFINES = $(PRJ_DEFINES) $(TCLSFE_DEFINES)

# Tcl config
TCLFULLVERSION = $(TCL_DOTVERSION)$(TCL_PATCH_LEVEL)
TCLSCRIPTZIP=$(STAGINGDIR)\lib\$(TCL_ZIP_FILE)

TCLSFERAW = $(OUT_DIR)\tclsfe-raw.exe
TCLSFE = $(OUT_DIR)\tclsfe.exe
TCLSFEVFS = $(OUT_DIR)\libtclsfe.vfs
TCLSFEZIP = $(OUT_DIR)\libtclsfe.zip

# Tk config

TKFULLVERSION = $(TK_DOTVERSION)$(TK_PATCH_LEVEL)
TKSCRIPTZIP=$(STAGINGDIR)\lib\$(TK_ZIP_FILE)

TKSFERAW = $(OUT_DIR)\tksfe-raw.exe
TKSFE = $(OUT_DIR)\tksfe.exe
TKSFEVFS = $(OUT_DIR)\libtksfe.vfs
TKSFEZIP = $(OUT_DIR)\libtksfe.zip

DISABLE_TARGET_install = 1
DISABLE_TARGET_pkgindex = 1
!include "$(_RULESDIR)\targets.vc"

sfe: tclsfe tksfe

tclsfe: $(OUT_DIR)\tclsfe.exe
tksfe: $(OUT_DIR)\tksfe.exe

$(TMP_DIR)\tclSfeMain.obj: $(TCLDIR)\win\tclAppInit.c
	$(cc32) $(appcflags_nostubs) /DTCL_LOCAL_MAIN_HOOK=TclMainHook /DUNICODE /D_UNICODE \
	    -Fo$@ $?

$(TMP_DIR)\tkSfeMain.obj: $(TKDIR)\win\winMain.c
	$(cc32) $(appcflags_nostubs) /DTK_LOCAL_MAIN_HOOK=TclMainHook /DUNICODE /D_UNICODE \
	    -Fo$@ $?

!if exists($(STAGINGDIR)\tclsfe_nmake.inc)
$(TMP_DIR)\tclSfeMainHook.obj: $(STAGINGDIR)\tclsfe_nmake.inc
!endif

$(TCLSFERAW): $(TMP_DIR)\tclSfeMain.obj $(TMP_DIR)\tclSfeMainHook.obj $(TMP_DIR)\tclsfe.exe.manifest
	$(CONEXECMD) -stack:2300000 $(TMP_DIR)\tclSfeMain.obj $(TMP_DIR)\tclSfeMainHook.obj
	copy $(TMP_DIR)\tclsfe.exe.manifest $(TCLSFERAW).manifest
	$(_VC_MANIFEST_EMBED_EXE)

$(TKSFERAW): $(TMP_DIR)\tkSfeMain.obj $(TMP_DIR)\tclSfeMainHook.obj $(TMP_DIR)\tksfe.exe.manifest
	$(GUIEXECMD) -stack:2300000 $(TMP_DIR)\tkSfeMain.obj $(TMP_DIR)\tclSfeMainHook.obj
	copy $(TMP_DIR)\tksfe.exe.manifest $(TKSFERAW).manifest
	$(_VC_MANIFEST_EMBED_EXE)

$(TCLSFE): $(TCLSFERAW) $(TCLSFEZIP)
	$(COPY) /b "$(TCLSFERAW)"+"$(TCLSFEZIP)" "$(TCLSFE)"

$(TKSFE): $(TKSFERAW) $(TKSFEZIP)
	$(COPY) /b "$(TKSFERAW)"+"$(TKSFEZIP)" "$(TKSFE)"

$(TCLSFEZIP): $(TCLSCRIPTZIP) .PHONY
        -@$(RMDIR) "$(TCLSFEVFS)"
        $(TCLSH_NATIVE) "$(ROOT)/library/unzip.tcl" "$(TCLSCRIPTZIP)" "$(TCLSFEVFS)"
        $(CPYDIR) "$(STAGINGDIR)\sfe.vfs\" "$(TCLSFEVFS)"
        $(TCLSH_NATIVE) "$(ROOT)/library/zipdir.tcl" "$(TCLSFEVFS)" "$(TCLSFEZIP)"

$(TKSFEZIP): $(TKSCRIPTZIP) .PHONY
        -@$(RMDIR) "$(TKSFEVFS)"
        $(TCLSH_NATIVE) "$(ROOT)/library/unzip.tcl" "$(TKSCRIPTZIP)" "$(TKSFEVFS)"
        $(CPYDIR) "$(STAGINGDIR)\sfe.vfs\" "$(TKSFEVFS)"
        $(TCLSH_NATIVE) "$(ROOT)/library/zipdir.tcl" "$(TKSFEVFS)" "$(TKSFEZIP)"

$(TMP_DIR)\tclsfe.exe.manifest: $(WIN_DIR)\tclsfe.exe.manifest.in
	@$(NMAKEHLP_NATIVE) -s << $** >$@
@MACHINE@	  $(MACHINE:IX86=X86)
@TCL_WIN_VERSION@  $(DOTVERSION).0.0
<<

$(TMP_DIR)\tksfe.exe.manifest: $(WIN_DIR)\tksfe.exe.manifest.in
	@$(NMAKEHLP_NATIVE) -s << $** >$@
@MACHINE@	  $(MACHINE:IX86=X86)
@TCL_WIN_VERSION@ $(DOTVERSION).0.0
@TK_WIN_VERSION@  $(DOTVERSION).0.0
<<

.PHONY:

pkgindex:
